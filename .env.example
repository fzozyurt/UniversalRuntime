UR_MODE=standalone
UR_PROFILE=local
UR_CONFIG_PATH=runtime.yaml

UR_GATEWAY_HOST=0.0.0.0
UR_GATEWAY_PORT=8080
UR_GATEWAY_CONTROL_GRPC_PORT=9092
UR_GRPC_HOST=0.0.0.0
UR_GRPC_PORT=9090

UR_WORKSPACE_KEY=default
UR_PROJECT_ID=default
UR_APPLICATION_ID=application
UR_REVISION_ID=development
UR_DEPLOYMENT_ID=application-local
ARTIFACT_VERSION=development

UR_WORKER_MAX_CONCURRENCY=8
UR_WORKER_DRAIN_TIMEOUT_SECONDS=30
UR_GATEWAY_CONTROL_GRPC_TARGET=gateway:9092
UR_WORKER_ADVERTISE_TARGET=worker:9090
UR_APPLICATION_ENTRYPOINTS=application.graph:graph

UR_APPLICATION_MIGRATIONS_PATH=
UR_APPLICATION_MIGRATION_REVISION=head
UR_APPLICATION_MIGRATION_METADATA=

UR_DATABASE_URL=postgresql+psycopg://runtime:runtime@postgres:5432/runtime
UR_DATABASE_SCHEMA_PREFIX=rt
UR_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
UR_TOPIC_PREFIX=rt
UR_KAFKA_ENVIRONMENT=local
UR_WORKER_CONSUMER_GROUP=rt.local.application.workers.v1

UR_APPLICATION_HTTP_TARGET=http://application-api:8000
UR_FASTAPI_ROUTERS_PACKAGE=application.http

UR_OBSERVABILITY_ENABLED=false
UR_OPENLIT_ENABLED=false
OTEL_SERVICE_NAME=universal-runtime
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
